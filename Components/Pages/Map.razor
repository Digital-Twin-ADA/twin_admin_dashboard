@page "/"
@page "/map"
@rendermode InteractiveServer
@using AdminDashboard.Models
@using AdminDashboard.Services
@inject IFestivalStompService StompService
@inject IFestivalDataService DataService
@inject IJSRuntime JSRuntime
@implements IDisposable

<PageTitle>Festival Dashboard</PageTitle>

<div class="dashboard-container">
    <div id="map" class="map-background"></div>

    <div class="overlay-panel glass-panel left-panel">
        <h2 class="panel-title">Festival Overview</h2>
        
        <div class="stages-container">
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="error-text" style="color: red; margin-bottom: 10px;">@errorMessage</div>
            }
            @if (isLoading)
            {
                <div class="loading-text">Loading festival data...</div>
            }
            else if (!stages.Any())
            {
                <div class="loading-text">Awaiting data...</div>
            }
            @foreach (var stage in stages)
            {
                <div class="stage-card">
                    <div class="stage-header">
                        <span class="stage-name">@stage.StageName</span>
                        <span class="stage-capacity">@stage.CurrentCapacity.ToString("N0") / @stage.MaxCapacity.ToString("N0")</span>
                    </div>
                    <div class="progress-bar-bg">
                        <div class="progress-bar-fill @(stage.FillPercentage > 0.8 ? "fill-critical" : (stage.FillPercentage > 0.6 ? "fill-warning" : "fill-safe"))" style="width: @(stage.FillPercentage * 100)%"></div>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="overlay-panel glass-panel right-panel">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
            <h2 class="panel-title" style="margin: 0; padding: 0; border: none;">Live Alerts</h2>
            @if(StompService.IsConnected)
            {
                <span style="background: rgba(40, 167, 69, 0.2); color: #28a745; padding: 4px 8px; border-radius: 12px; font-size: 0.75em; border: 1px solid #28a745;">
                    <i class="bi bi-circle-fill" style="font-size: 0.6em; margin-right: 4px; vertical-align: middle;"></i> STOMP Connected
                </span>
            }
            else
            {
                <span style="background: rgba(220, 53, 69, 0.2); color: #dc3545; padding: 4px 8px; border-radius: 12px; font-size: 0.75em; border: 1px solid #dc3545;">
                    <i class="bi bi-circle-fill" style="font-size: 0.6em; margin-right: 4px; vertical-align: middle;"></i> STOMP Disconnected
                </span>
            }
        </div>
        <div class="alerts-container">
            @if (!alerts.Any())
            {
                <div class="loading-text">No active alerts...</div>
            }
            @foreach (var alert in alerts.OrderByDescending(a => a.Timestamp).Take(5))
            {
                <div class="alert-card alert-@alert.Type.ToLower()">
                    <div class="alert-icon">
                        @if(alert.Type == "Critical") { <span class="bi bi-exclamation-triangle-fill"></span> }
                        else if(alert.Type == "Warning") { <span class="bi bi-exclamation-circle-fill"></span> }
                        else { <span class="bi bi-info-circle-fill"></span> }
                    </div>
                    <div class="alert-content">
                        <div class="alert-message">@alert.Message</div>
                        <div class="alert-time">@alert.Timestamp.ToLocalTime().ToString("HH:mm:ss")</div>
                    </div>
                </div>
            }
        </div>
        
        <div class="quick-actions">
            <button class="action-btn btn-primary" disabled="@(!StompService.IsConnected)" @onclick="() => showSendAlertModal = true"><span class="bi bi-broadcast"></span> Send Alert</button>
            <button class="action-btn btn-secondary"><span class="bi bi-people-fill"></span> Dispatch Staff</button>
        </div>
    </div>
</div>

@if (showSendAlertModal)
{
    <div class="modal-overlay" style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.6); z-index: 1000; display: flex; align-items: center; justify-content: center;">
        <div class="glass-panel" style="width: 400px; padding: 25px; border-radius: 12px; background: rgba(20, 20, 25, 0.95);">
            <h3 style="color: white; margin-top: 0;">Send Custom Alert</h3>
            
            <div style="margin-bottom: 15px;">
                <label style="color: #aaa; font-size: 0.9em;">Stage:</label>
                <select @bind="newAlert.StageId" style="width:100%; padding: 8px; border-radius: 4px; border: 1px solid #444; background: #222; color: white;">
                    <option value="0">Select a stage...</option>
                    @foreach(var stage in stages)
                    {
                        <option value="@stage.StageId">@stage.StageName</option>
                    }
                </select>
            </div>
            
            <div style="margin-bottom: 15px;">
                <label style="color: #aaa; font-size: 0.9em;">Type:</label>
                <select @bind="newAlert.Type" style="width:100%; padding: 8px; border-radius: 4px; border: 1px solid #444; background: #222; color: white;">
                    <option value="SAFETY">SAFETY</option>
                    <option value="MEDICAL">MEDICAL</option>
                    <option value="CROWD">CROWD</option>
                    <option value="SECURITY">SECURITY</option>
                    <option value="INFO">INFO</option>
                </select>
            </div>
            
            <div style="margin-bottom: 15px;">
                <label style="color: #aaa; font-size: 0.9em;">Severity:</label>
                <select @bind="newAlert.Severity" style="width:100%; padding: 8px; border-radius: 4px; border: 1px solid #444; background: #222; color: white;">
                    <option value="HIGH">HIGH</option>
                    <option value="MEDIUM">MEDIUM</option>
                    <option value="LOW">LOW</option>
                </select>
            </div>
            
            <div style="margin-bottom: 20px;">
                <label style="color: #aaa; font-size: 0.9em;">Message:</label>
                <textarea @bind="newAlert.Message" rows="3" style="width:100%; padding: 8px; border-radius: 4px; border: 1px solid #444; background: #222; color: white; resize: vertical;"></textarea>
            </div>
            
            <div style="display: flex; gap: 10px;">
                <button class="action-btn btn-primary" @onclick="SubmitAlert" style="flex: 1;">Send Alert</button>
                <button class="action-btn btn-secondary" @onclick="() => showSendAlertModal = false" style="flex: 1;">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    private List<StageCapacity> stages = new();
    private List<AlertMessage> alerts = new();
    private double baseLat = 46.7688;
    private double baseLng = 23.5700;
    private bool _stagesDrawn = false;
    private bool isLoading = true;
    private string errorMessage = string.Empty;
    
    private bool showSendAlertModal = false;
    private CustomAlertRequest newAlert = new CustomAlertRequest { Type = "SAFETY", Severity = "HIGH" };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var festivalInfo = await DataService.GetFestivalInfoAsync();
            
            if (festivalInfo != null)
            {
                baseLat = festivalInfo.Latitude;
                baseLng = festivalInfo.Longitude;
                
                StompService.Initialize(festivalInfo);
            }
            else
            {
                errorMessage = "Failed to load festival data. Using defaults.";
                StompService.Initialize(new FestivalInfo 
                { 
                    Latitude = baseLat, 
                    Longitude = baseLng 
                });
            }

            isLoading = false;
            StateHasChanged();

            await JSRuntime.InvokeVoidAsync("mapInterop.initializeMap", "map", baseLat, baseLng);

            StompService.OnHeatmapUpdated += HandleHeatmapUpdate;
            StompService.OnStagesUpdated += HandleStagesUpdate;
            StompService.OnAlertReceived += HandleAlertReceived;
            StompService.OnConnectionStateChanged += HandleConnectionStateChanged;

            await StompService.ConnectAsync();
        }
    }

    private async void HandleHeatmapUpdate(List<HeatmapPoint> points)
    {
        await InvokeAsync(async () =>
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("mapInterop.updateHeatmap", points);
            }
            catch (TaskCanceledException) { }
            catch (Exception ex) when (ex.GetType().Name == "JSDisconnectedException") { }
        });
    }

    private void HandleStagesUpdate(List<StageCapacity> newStages)
    {
        InvokeAsync(async () =>
        {
            try
            {
                stages = newStages;
                StateHasChanged();

                if (!_stagesDrawn && stages.Any())
                {
                    _stagesDrawn = true;
                    await JSRuntime.InvokeVoidAsync("mapInterop.drawStages", stages);
                }
            }
            catch (TaskCanceledException) { }
            catch (Exception ex) when (ex.GetType().Name == "JSDisconnectedException") { }
        });
    }

    private void HandleAlertReceived(AlertMessage alert)
    {
        InvokeAsync(() =>
        {
            alerts.Insert(0, alert);
            if (alerts.Count > 10) alerts.RemoveAt(alerts.Count - 1);
            StateHasChanged();
        });
    }

    private void HandleConnectionStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        StompService.OnHeatmapUpdated -= HandleHeatmapUpdate;
        StompService.OnStagesUpdated -= HandleStagesUpdate;
        StompService.OnAlertReceived -= HandleAlertReceived;
        StompService.OnConnectionStateChanged -= HandleConnectionStateChanged;
    }

    private async Task SubmitAlert()
    {
        if (newAlert.StageId == 0 || string.IsNullOrEmpty(newAlert.Type) || string.IsNullOrEmpty(newAlert.Severity))
        {
            if (newAlert.StageId == 0) return;
        }

        await StompService.SendAlertAsync(newAlert);
        
        newAlert = new CustomAlertRequest { Type = "SAFETY", Severity = "HIGH" };
        showSendAlertModal = false;
    }
}
